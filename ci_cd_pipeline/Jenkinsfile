pipeline {
    agent any

    stages {
        stage('Build') {
            steps {
                echo 'Installing dependencies...'
                script {
                    try {
                        dir('ci_cd_pipeline') {
                            sh 'chmod +x ./scripts/install_python_env.sh'
                            sh './scripts/install_python_env.sh'
                        }
                    } catch (err) {
                        echo "Caught: ${err}"
                        currentBuild.result = 'FAILURE'
                        error "Lo script di installazione è fallito: ${err.getMessage()}"
                    }
                }
            }
        }
        stage('Test') {
            steps {
                echo 'Testing..'
            }
        }
        stage('Deploy') {
            steps {
                echo 'Deploying....'
            }
        }
    }
}
